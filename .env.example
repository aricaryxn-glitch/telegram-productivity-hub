APP_NAME="Telegram Productivity Hub"
ENVIRONMENT=development
DATABASE_URL=sqlite:///./hub.db
REDIS_URL=redis://localhost:6379/0
BOT_TOKEN=replace-with-your-telegram-bot-token
ADMIN_IDS=123456789
FORCED_CHANNEL=@YourChannel
FREE_DAILY_CONVERSIONS=10
REFERRAL_REWARD_CONVERSIONS=3
REFERRAL_REWARD_PREMIUM_DAYS=0
STORAGE_DIR=storage
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OCR_LANGUAGES=eng+hin+rus+ara
REMOVE_BG_API_KEY=
WEBHOOK_BASE_URL=https://your-domain.com
TELEGRAM_WEBHOOK_SECRET=
